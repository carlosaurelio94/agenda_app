{
  "buildCommand": "ng build --configuration production",
  "outputDirectory": "dist/agenda-app/browser",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/check-alerts",
      "schedule": "0 14 * * 1-5"
    }
  ]
}
